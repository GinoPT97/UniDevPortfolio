        <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_P87JsKxfEeyZvr3XTS9xSg" name="connectionExists" specification="_Pw9xUKxfEeyZvr3XTS9xSg">
          <ownedParameter xmi:id="_P87JsaxfEeyZvr3XTS9xSg" direction="return">
