          </ownedParameter>
          <ownedParameter xmi:id="_P9B3ZaxfEeyZvr3XTS9xSg" type="_P5olIKxfEeyZvr3XTS9xSg" direction="return">
            <name xsi:nil="true"/>
          </ownedParameter>
          <language>java</language>
          <body>ResultSet rs = getAllCalc.executeQuery();&#xD;
     while(rs.next())&#xD;
     {&#xD;
     	calcal.add(new Calc(rs.getFloat(&quot;operando1&quot;), rs.getFloat(&quot;operando&quot;),rs.getString(&quot;operatore&quot;), rs.getFloat(&quot;risultato&quot;)));&#xD;
     }&#xD;
     rs.close();&#xD;
     return calcal;&#xD;
	</body>
        </ownedBehavior>
