            <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
          </ownedParameter>
          <ownedParameter xmi:id="_P88X1axfEeyZvr3XTS9xSg" type="_PxD38KxfEeyZvr3XTS9xSg" direction="return">
            <name xsi:nil="true"/>
          </ownedParameter>
          <language>java</language>
          <body>if (instance == null)&#xD;
     {&#xD;
         instance = new DBConnect(db);&#xD;
     }&#xD;
     else&#xD;
         if (instance.getConnection().isClosed())&#xD;
         {&#xD;
             instance = new DBConnect(db);&#xD;
         }&#xD;
&#xD;
     return instance;&#xD;
 </body>
        </ownedBehavior>
