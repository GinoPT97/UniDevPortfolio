        <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_P9LBUKxfEeyZvr3XTS9xSg" name="StoricoFrame" specification="_P65wcKxfEeyZvr3XTS9xSg">
          <ownedParameter xmi:id="_P9LBUaxfEeyZvr3XTS9xSg" name="string">
            <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
