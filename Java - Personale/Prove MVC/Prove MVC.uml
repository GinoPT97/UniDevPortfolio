        <ownedAttribute xmi:id="_qyWUBKxfEeyZvr3XTS9xSg" name="pe" visibility="private" type="_qx3L0KxfEeyZvr3XTS9xSg" association="_qysSQKxfEeyZvr3XTS9xSg">
          <defaultValue xmi:type="uml:LiteralString" xmi:id="_qyW7EaxfEeyZvr3XTS9xSg" value="new ArrayList&lt;provaentita>()"/>
        </ownedAttribute>
        <ownedAttribute xmi:id="_qykWcKxfEeyZvr3XTS9xSg" name="inserisciprove" visibility="private" type="_qyLU4KxfEeyZvr3XTS9xSg" association="_qyyY4axfEeyZvr3XTS9xSg"/>
        <ownedAttribute xmi:id="_qyk9gaxfEeyZvr3XTS9xSg" name="updateprove" visibility="private" type="_qyLU4KxfEeyZvr3XTS9xSg" association="_qyy_8axfEeyZvr3XTS9xSg"/>
        <ownedAttribute xmi:id="_qyk9hKxfEeyZvr3XTS9xSg" name="cancellaprove" visibility="private" type="_qyLU4KxfEeyZvr3XTS9xSg" association="_qyznAKxfEeyZvr3XTS9xSg"/>
        <interfaceRealization xmi:id="_qx4Z8axfEeyZvr3XTS9xSg" client="_qwItgKxfEeyZvr3XTS9xSg" supplier="_qwbocKxfEeyZvr3XTS9xSg" contract="_qwbocKxfEeyZvr3XTS9xSg"/>
        <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_qygFBqxfEeyZvr3XTS9xSg" name="provadaoimpl" specification="_qyL78KxfEeyZvr3XTS9xSg">
          <ownedParameter xmi:id="_qygFB6xfEeyZvr3XTS9xSg" name="connection" type="_qxweIKxfEeyZvr3XTS9xSg"/>
          <ownedParameter xmi:id="_qygFCKxfEeyZvr3XTS9xSg" type="_qwItgKxfEeyZvr3XTS9xSg" direction="return">
            <name xsi:nil="true"/>
          </ownedParameter>
          <language>java</language>
          <body>this.connection = connection;&#xD;
     cancellaprove = connection.prepareStatement(&quot;DELETE FROM prove WHERE id = ?&quot;);&#xD;
     getprove = connection.prepareStatement(&quot;SELECT * FROM prove ORDER BY corso DESC&quot;);&#xD;
     inserisciprove = connection.prepareStatement(&quot;INSERT INTO prove VALUES (NEXTVAL('seqid'), ?, ?, ?)&quot;);&#xD;
     updateprove = connection.prepareStatement(&quot;UPDATE prove SET nome = ?, contatto = ?, corso = ? WHERE id = ?&quot;);&#xD;
 </body>
        </ownedBehavior>
        <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_qygFCaxfEeyZvr3XTS9xSg" name="getAllprova" specification="_qwJ7oKxfEeyZvr3XTS9xSg">
          <ownedParameter xmi:id="_qygFCqxfEeyZvr3XTS9xSg" type="_qx3L0KxfEeyZvr3XTS9xSg" direction="return">
            <name xsi:nil="true"/>
          </ownedParameter>
          <language>java</language>
          <body>ResultSet rs = getprove.executeQuery();&#xD;
     while(rs.next())&#xD;
     	pe.add(new provaentita(rs.getString(&quot;id&quot;),rs.getString(&quot;nome&quot;), rs.getString(&quot;contatto&quot;),rs.getString(&quot;corso&quot;)));&#xD;
     rs.close();&#xD;
     return pe;&#xD;
	</body>
        </ownedBehavior>
        <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_qygFC6xfEeyZvr3XTS9xSg" name="inserisciprove" specification="_qx5oEKxfEeyZvr3XTS9xSg">
          <ownedParameter xmi:id="_qygFDKxfEeyZvr3XTS9xSg" name="pe" type="_qwQCQKxfEeyZvr3XTS9xSg"/>
          <ownedParameter xmi:id="_qygFDaxfEeyZvr3XTS9xSg" direction="return">
            <name xsi:nil="true"/>
            <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/JavaPrimitiveTypes.library.uml#boolean"/>
          </ownedParameter>
          <language>java</language>
          <body>inserisciprove.setString(1, pe.getnome());&#xD;
     inserisciprove.setString(2, pe.getcontatto());&#xD;
     inserisciprove.setString(3, pe.getcorso());&#xD;
