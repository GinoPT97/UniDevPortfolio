        <ownedAttribute xmi:id="_qyVs9qxfEeyZvr3XTS9xSg" name="connection" visibility="private" type="_qxweIKxfEeyZvr3XTS9xSg" association="_qyrEIaxfEeyZvr3XTS9xSg"/>
