@startuml DiagramNonRistrutturato
skinparam class {
  BackgroundColor #F9F9F9
  ArrowColor #2D6A4F
  BorderColor #2D6A4F
  FontName "Segoe UI"
  FontSize 12
  AttributeFontColor #333333
  StereotypeFontColor #2D6A4F
  StereotypeFontSize 11
}

' Layout ordinato con posizionamento esplicito
left to right direction

enum TIPOLOGIA {
  FRUTTA
  VERDURA
  FARINACEI
  LATTICINI
  UOVA
  CONFEZIONATI
}
enum STATOTESSERA {
  ATTIVA
  SOSPESA
  SCADUTA
}

abstract class Utente {
  +codicefiscale: CHAR(16)
  nome: VARCHAR(255)
  cognome: VARCHAR(255)
  indirizzo: VARCHAR(255)
  telefono: VARCHAR(20)
  email: VARCHAR(255)
}
class Cliente {
  +codcliente: SERIAL
}
class Dipendente {
  +coddipendente: SERIAL
}
Utente <|-- Cliente
Utente <|-- Dipendente

class Tessera {
  +codtessera: SERIAL
  codcliente: INTEGER <<UNIQUE>>
  numeropunti: NUMERIC
  dataemissione: DATE
  datascadenza: DATE
  stato: STATOTESSERA
}

class Ordine {
  +codordine: SERIAL
  prezzototale: REAL
  dataacquisto: DATE
  codcliente: INTEGER
  coddipendente: INTEGER
}
class ArticoliOrdine {
  codordine: INTEGER
  codprodotto: INTEGER
  prezzo: NUMERIC
  numeroarticoli: INT
}

abstract class Prodotto {
  +codprodotto: SERIAL
  nome: VARCHAR(255)
  descrizione: VARCHAR(500)
  prezzo: NUMERIC
  luogoprovenienza: VARCHAR(255)
  dataraccolta: DATE
  datamungitura: DATE
  dataproduzione: DATE
  datascadenza: DATE
  glutine: BOOLEAN
  categoria: TIPOLOGIA
  scorta: INT
}
class Frutta {
  dataraccolta: DATE
}
class Verdura {
  dataraccolta: DATE
}
class Farinacei {
  glutine: BOOLEAN
}
class Latticini {
  datamungitura: DATE
  dataproduzione: DATE
  datascadenza: DATE
}
class Uova {
  datascadenza: DATE
}
class Confezionati {
  datascadenza: DATE
}
Prodotto <|-- Frutta
Prodotto <|-- Verdura
Prodotto <|-- Farinacei
Prodotto <|-- Latticini
Prodotto <|-- Uova
Prodotto <|-- Confezionati


' Relazioni tra le classi con etichette e ruoli
Cliente "1" -- "1" Tessera : possiede/intestata a >
Cliente "1" -- "*" Ordine : effettua >
Dipendente "1" -- "*" Ordine : gestisce >
Ordine "1" -- "*" ArticoliOrdine : contiene/appartiene a >
ArticoliOrdine "*" -- "1" Prodotto : si riferisce a >

@enduml
