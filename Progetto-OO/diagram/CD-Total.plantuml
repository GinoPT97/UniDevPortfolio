ArticoliImpl                -[#008200,dashed]-^  ArticoliJDBC
Cliente                    "1" *-[#595959,plain]-> "tessera\n1" Tessera : possiede
Cliente                    "1" o-[#000000,plain]-> "ordini\n*" Ordine : effettua
Dipendente                 "1" o-[#000000,plain]-> "ordini\n*" Ordine : gestisce
Ordine                     "1" o-[#000000,plain]-> "articoli\n*" Articoli : contiene
Clienteimpl                 -[#008200,dashed]-^  ClienteJDBC
Controller                 "1" *-[#595959,plain]-> "adminf\n1" AdminFrame : gestisce
Controller                 "1" *-[#595959,plain]-> "articoli\n1" Articoli
Controller                 "1" *-[#595959,plain]-> "artjdbc\n1" ArticoliJDBC
Controller                 "1" *-[#595959,plain]-> "carrf\n1" CarrelloFrame : gestisce
Controller                 "1" *-[#595959,plain]-> "cliente\n1" Cliente
Controller                 "1" *-[#595959,plain]-> "cljdbc\n1" ClienteJDBC
Controller                 "1" *-[#595959,plain]-> "config\n1" DBConfiguration
Controller                 "1" *-[#595959,plain]-> "dbconn\n1" DBConnection
Controller                 "1" *-[#595959,plain]-> "dipendente\n1" Dipendente
Controller                 "1" *-[#595959,plain]-> "dipf\n1" DipendenteFrame : gestisce
Controller                 "1" *-[#595959,plain]-> "dpjdbc\n1" DipendenteJDBC
Controller                 "1" *-[#595959,plain]-> "logf\n1" LoginFrame : gestisce
Controller                 "1" *-[#595959,plain]-> "upclf\n1" ModificaClienteFrame : modifica
Controller                 "1" *-[#595959,plain]-> "updipf\n1" ModificaDipendenteFrame : modifica
