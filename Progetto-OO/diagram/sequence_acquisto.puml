@startuml sequence_acquisto

actor Dipendente
participant "CarrelloFrame" as GUI
participant "Controller"
participant "ProdottoImpl"
participant "OrdiniImpl"

Dipendente -> GUI: seleziona prodotto
GUI -> Controller: aggiungiAlCarrello(idProdotto)
Controller -> ProdottoImpl: getProdotto(idProdotto)
alt Prodotto disponibile
    ProdottoImpl --> Controller: prodotto
    Controller --> GUI: aggiorna carrello
    GUI -> Dipendente: prodotto aggiunto
else Prodotto non disponibile
    ProdottoImpl --> Controller: errore disponibilità
    Controller --> GUI: mostra errore
    GUI -> Dipendente: messaggio errore
end

Dipendente -> GUI: conferma acquisto
GUI -> Controller: confermaOrdine(carrello)
Controller -> OrdiniImpl: creaOrdine(carrello)
alt Ordine registrato
    OrdiniImpl --> Controller: esito positivo
    Controller --> GUI: mostra conferma ordine
    GUI -> Dipendente: ordine confermato
else Errore ordine
    OrdiniImpl --> Controller: errore ordine
    Controller --> GUI: mostra errore ordine
    GUI -> Dipendente: messaggio errore
end
@enduml
