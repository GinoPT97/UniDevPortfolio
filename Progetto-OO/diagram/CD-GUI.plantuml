Controller                 "1" *-[#595959,plain]-> "updipf\n1" ModificaDipendenteFrame : modifica
Controller                 "1" *-[#595959,plain]-> "modprodf\n1" ModificaProdottiFrame : modifica
Controller                 "1" *-[#595959,plain]-> "nclf\n1" NuovoClienteFrame : crea
Controller                 "1" *-[#595959,plain]-> "ndipf\n1" NuovoDipendenteFrame : crea
Controller                 "1" *-[#595959,plain]-> "nprodf\n1" NuovoProdottoFrame : crea
Controller                 "1" *-[#595959,plain]-> "searchf\n1" RicercaFrame : ricerca
Controller                 "1" *-[#595959,plain]-> "statdipf\n1" StatisticheDipendentiFrame : analizza
Controller                 "1" *-[#595959,plain]-> "visctf\n1" VisioneClienteFrame : visualizza
Controller                 "1" *-[#595959,plain]-> "vdipf\n1" VisioneDipendentiFrame : visualizza
Controller                 "1" *-[#595959,plain]-> "visordf\n1" VisioneOrdineFrame : visualizza
Controller                 "1" *-[#595959,plain]-> "vprodf\n1" VisioneProdottiFrame : visualizza
