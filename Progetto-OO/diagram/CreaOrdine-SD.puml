' Flusso fedele al codice Java
@startuml CreaOrdine-SD
actor Utente
participant CarrelloFrame
participant Controller
participant OrdiniJDBC
participant ProdottoJDBC
participant ArticoliJDBC
participant TesseraJDBC

Utente -> CarrelloFrame : creaOrdine(c)
activate CarrelloFrame
CarrelloFrame -> CarrelloFrame : calcolaTotale()
CarrelloFrame -> Controller : nuovoordine(codOrdine, dataAcquisto, totale, idCliente, idDipendente)
activate Controller
Controller -> OrdiniJDBC : newordine(ordine)
activate OrdiniJDBC
OrdiniJDBC --> Controller : esito
deactivate OrdiniJDBC
alt Errore creazione ordine
    Controller --> CarrelloFrame : showError("Errore nella creazione dell'ordine!")
    deactivate Controller
    deactivate CarrelloFrame
else Ordine creato
    Controller -> Controller : updateOrdineModelAfterInsert(...)
    Controller --> CarrelloFrame : conferma creazione
    deactivate Controller
    CarrelloFrame -> Controller : CurrOrd()
    activate Controller
    Controller --> CarrelloFrame : codOrdine
    deactivate Controller
    CarrelloFrame -> CarrelloFrame : processArticoli(c, codOrdine)
    CarrelloFrame -> Controller : newarticoli(...)
    activate Controller
    Controller -> ArticoliJDBC : newordine(articoli)
    activate ArticoliJDBC
    ArticoliJDBC --> Controller : esito
    deactivate ArticoliJDBC
    Controller --> CarrelloFrame : esito
    deactivate Controller
    CarrelloFrame -> CarrelloFrame : assegnaPunti(c, idCliente, totale)
    CarrelloFrame -> Controller : uppunti(codcl, punti)
    activate Controller
    Controller -> TesseraJDBC : updatepunti(codcl, punti)
    activate TesseraJDBC
    TesseraJDBC --> Controller : esito
    deactivate TesseraJDBC
    Controller --> CarrelloFrame : esito
    deactivate Controller
    CarrelloFrame -> CarrelloFrame : clean()
end
deactivate CarrelloFrame

@enduml
' Flusso principale: creazione ordine
Utente -> CarrelloFrame : creaOrdine()
activate CarrelloFrame
CarrelloFrame -> CarrelloFrame : verificaDatiCarrello()
alt Dati non validi
    CarrelloFrame -> CarrelloFrame : mostraErroreValidazione()
    CarrelloFrame -> CarrelloFrame : evidenziaCampiErrati()
    deactivate CarrelloFrame
else Dati validi
    CarrelloFrame -> CarrelloFrame : calcolaTotaleCarrello()
    CarrelloFrame -> Controller : richiediCreazioneOrdine(dati, totale)
    deactivate CarrelloFrame
    activate Controller
    create Ordine
    Controller -> Ordine : inizializzaOrdine(dati, totale)
    activate Ordine
    Ordine --> Controller : confermaInizializzazione
    deactivate Ordine
    Controller -> OrdiniJDBC : persistiOrdine(ordine)
    activate OrdiniJDBC
    OrdiniJDBC --> Controller : confermaPersistenza
    deactivate OrdiniJDBC
    Controller -> Controller : aggiornaModelloOrdine()
    Controller -> Controller : eseguiControlliFinali()
    Controller -> Controller : generaRowData()
    Controller --> CarrelloFrame : notificaCreazioneOrdine()
    deactivate Controller
    activate CarrelloFrame
    CarrelloFrame -> CarrelloFrame : mostraConfermaCreazioneOrdine()
    ' Aggiornamento scorte prodotti
    CarrelloFrame -> Controller : aggiornaScorteProdotti()
    activate Controller
    Controller -> ProdottoJDBC : aggiornaScorte()
    activate ProdottoJDBC
    ProdottoJDBC --> Controller : confermaAggiornamentoScorte
    deactivate ProdottoJDBC
    Controller --> CarrelloFrame : scorteAggiornate
    deactivate Controller
    ' Aggiunta articoli all'ordine
    CarrelloFrame -> Controller : aggiungiArticoliOrdine()
    activate Controller
    create Articoli
    Controller -> Articoli : inizializzaArticoli()
    activate Articoli
    Articoli --> Controller : confermaInizializzazione
    deactivate Articoli
    Controller -> ArticoliJDBC : persistiArticoli(articoli)
    activate ArticoliJDBC
    ArticoliJDBC --> Controller : confermaPersistenza
    deactivate ArticoliJDBC
    Controller --> CarrelloFrame : articoliAggiunti
    deactivate Controller
    ' Aggiornamento punti tessera
    CarrelloFrame -> Controller : aggiornaPuntiTessera()
    activate Controller
    Controller -> TesseraJDBC : aggiornaPunti()
    activate TesseraJDBC
    TesseraJDBC --> Controller : confermaAggiornamentoPunti
    deactivate TesseraJDBC
    Controller --> CarrelloFrame : puntiAggiornati
    deactivate Controller
    CarrelloFrame -> CarrelloFrame : pulisciCarrello()
end
deactivate CarrelloFrame

@enduml