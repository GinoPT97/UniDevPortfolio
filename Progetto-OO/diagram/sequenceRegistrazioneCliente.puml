@startuml sequenceRegistrazioneCliente


actor Dipendente
participant "VisioneClienteFrame" as VisioneGUI
participant "NuovoClienteFrame" as GUI
participant "Controller"
participant "ClienteImpl"


Dipendente -> VisioneGUI: seleziona "Nuovo Cliente"
VisioneGUI -> GUI: apri form di inserimento dati
GUI -> Dipendente: mostra form di inserimento dati
Dipendente -> GUI: inserisce dati e conferma
GUI -> Controller: registraNuovoCliente(datiCliente)
Controller -> ClienteImpl: salvaCliente(datiCliente)
alt Registrazione riuscita
    ClienteImpl --> Controller: conferma salvataggio
    Controller --> GUI: conferma registrazione
    GUI -> Dipendente: cliente registrato con successo
    GUI -> VisioneGUI: apri schermata lista clienti
    VisioneGUI -> Controller: aggiorna e mostra lista clienti
    Controller -> ClienteImpl: recuperaClienti()
    ClienteImpl --> Controller: lista clienti aggiornata
    Controller --> VisioneGUI: lista clienti aggiornata
    VisioneGUI -> Dipendente: mostra lista clienti aggiornata
    Dipendente -> VisioneGUI: seleziona cliente o effettua altre operazioni
else Errore registrazione
    ClienteImpl --> Controller: errore salvataggio
    Controller --> GUI: errore registrazione
    GUI -> Dipendente: errore durante la registrazione
end

@enduml
