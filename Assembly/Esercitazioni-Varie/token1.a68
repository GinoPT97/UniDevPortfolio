* CERCA TOKEN IN STRING 

	ORG	$8000	      

START	MOVEA.L #STRING,A0
	MOVE.B  #TOKEN,D0
LOOP	CMP.B	  #TAPPO,(A0)
	BEQ      DONE
	CMP.B	  (A0)+,D0
	BNE	  LOOP
	SUBQ.L  #1,A0
	MOVEA.L A0,A1
DONE	JMP       DONE

	
           ORG	$8100

STRING           DC.B	'QUI QUO:QUA',0
TOKEN	            EQU	':'
TAPPO	            EQU    $0

          END	START




