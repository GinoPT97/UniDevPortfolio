* Esercizio 2
* Realizzare un programma che conti il numero di volte in cui compare il carattere 'A' all'interno di una 
* stringa e ponga tale numero nel registro D3.

		ORG	$8000

START		MOVE		#0,D3
		MOVE.B	X,D0
		MOVEA.L	#S,A0
LOOP		MOVE.B	(A0)+,D1
		TST.B		D1
		BEQ		FINE
		CMP.B		D0,D1
		BNE		L1
		ADDQ		#1,D3
L1		BRA		LOOP
FINE		STOP		#$2000		



		ORG	$8800
S		DC.B	'PROGRAMMA DI PROVA',0
X		DC.B	'A'
		END START




