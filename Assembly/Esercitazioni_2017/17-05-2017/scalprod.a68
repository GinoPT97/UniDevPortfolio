* File: scalprod.a68 - Compute scalar product
	ORG	 $8000	          Start at location 8000 Hex
* Initialize
START	MOVE.L #A,A0
	MOVE.L #B,A1
	MOVE.L #N,D0
	SUBQ	 #1,D0
	CLR.L	 D2
LOOP  MOVE	(A0)+,D1
	MULS	(A1)+,D1
	ADD	 D1,D2
	DBRA	 D0,LOOP
	MOVE	 D2,C
DONE	JMP	 DONE
N	EQU	 $000A

	ORG	 $80B0
A	DC.W	 1,2,3,1,1,1,1,1,1,1
	ORG	 $80D0
B	DC.W	 4,5,6,1,1,1,1,1,1,1
C	DS.L	 1
