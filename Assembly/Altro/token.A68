* Programma per ricercare dentro una stringa di caratteri un carattere speciale e salvarne 
*l'indirizzo di memoria

		ORG		$8000
START		MOVEA.L	#STRING,A0
		MOVE.B	#TOKEN,D0
LOOP		TST.B		(A0)
		BEQ		DONE
		CMP.B		(A0)+,D0
		BNE		LOOP
FOUND	SUBA.L	#1,A0
DONE		MOVE.L  	A0,TOKENA
		STOP		#$2700
*
		ORG	   $8100
TOKEN		EQU	   ':'
STRING 	DC.B	   'QUI QUO:QUA',0
TOKENA 	DS.L	   1
		END	   START




