00008008  6700 001C                         15  		BEQ		FINECICLO		Se e' il terminatore esce dal ciclo
0000800C  0C10 0061                         16  		CMP.B		#'a',(A0)		Se e' minore 'a', non convertire
00008010  6500 000E                         17  		BLO		NONCONV
00008014  0C10 007A                         18  		CMP.B		#'z',(A0)		Se e' maggiore di 'z', non convertire
